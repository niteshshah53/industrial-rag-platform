# ============================================================
# Industrial RAG Platform — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
#
# All variables have sensible defaults for local Docker Compose
# development. Only override what you need to change.
# ============================================================

# ── Application ──────────────────────────────────────────────
# Environment: development | production | test
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: text (human-readable) | json (structured, for production)
LOG_FORMAT=text

# ── Ollama (LLM + Embedding) ──────────────────────────────────
# Base URL for the Ollama HTTP API.
# Use http://ollama:11434 when running inside Docker Compose.
# Use http://localhost:11434 when running outside Docker.
OLLAMA_BASE_URL=http://ollama:11434

# LLM used for answer generation.
# Must be pulled in Ollama before use: ollama pull llama3.2:3b
LLM_MODEL=llama3.2:3b

# Embedding model used for document chunks and query vectors.
# Must be pulled in Ollama before use: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Output dimensionality of the embedding model.
# nomic-embed-text produces 768-dimensional vectors.
# MUST match the Qdrant collection vector size — do not change after collection creation.
EMBEDDING_DIMENSIONS=768

# ── Qdrant (Vector Database) ──────────────────────────────────
# Hostname of the Qdrant service.
# Use qdrant when running inside Docker Compose.
QDRANT_HOST=qdrant

# Qdrant REST API port.
QDRANT_PORT=6333

# Qdrant gRPC port (used by the Python client for better performance).
QDRANT_GRPC_PORT=6334

# Name of the Qdrant collection that stores document chunk vectors.
QDRANT_COLLECTION_NAME=documents

# Distance metric used for vector similarity.
# Must match the embedding model's training objective.
# nomic-embed-text uses Cosine similarity.
# Options: Cosine | Dot | Euclidean
QDRANT_DISTANCE_METRIC=Cosine

# ── Chunking ─────────────────────────────────────────────────
# Document chunk size in CHARACTERS (not tokens).
# RecursiveCharacterTextSplitter counts characters.
# 1024 characters ≈ 256 tokens at ~4 chars/token.
CHUNK_SIZE_CHARS=1024

# Number of overlapping characters between consecutive chunks.
# Preserves context across chunk boundaries.
CHUNK_OVERLAP_CHARS=128

# ── Retrieval ─────────────────────────────────────────────────
# Default number of chunks to retrieve per query.
DEFAULT_TOP_K=5

# Minimum cosine similarity score for a chunk to be included in context.
# Range: 0.0–1.0. This is a hyperparameter — tune using the evaluation pipeline.
# A value too high filters all results; too low includes irrelevant chunks.
RELEVANCE_SCORE_THRESHOLD=0.6

# Maximum total characters for assembled LLM context.
# ≈ 2048 tokens at ~4 chars/token. Prevents context window overflow.
MAX_CONTEXT_CHARS=8192

# ── Embedding ─────────────────────────────────────────────────
# Number of chunks to embed per Ollama API call.
# Larger batches are faster but use more memory.
EMBEDDING_BATCH_SIZE=32

# ── Ingestion ─────────────────────────────────────────────────
# Maximum allowed upload file size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# Directory where raw uploaded files are stored.
# Must be an absolute path or relative to the working directory.
UPLOAD_DIR=./uploads

# Maximum number of concurrent background ingestion jobs.
# Prevents Ollama from being overwhelmed during bulk uploads.
INGESTION_CONCURRENCY=2
